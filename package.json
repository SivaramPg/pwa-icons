{
  "name": "pwa-asset-generator",
  "version": "1.0.0",
  "description": "Generate PWA icons for iOS, Android, and Windows 11 from a single source image",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "pwa-asset-generator": "./src/index.ts",
    "pwa-icons": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/pwa-asset-generator",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pwa",
    "icons",
    "asset-generator",
    "ios",
    "android",
    "windows11",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "p-limit": "^7.2.0",
    "sharp": "^0.34.5"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
