{
  "name": "pwa-icons",
  "version": "2.0.0",
  "description": "Fast, interactive CLI to generate PWA icons for iOS, Android, Windows 11 and favicons from a single source image",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": {
    "pwa-icons": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "lefthook install"
  },
  "keywords": [
    "pwa",
    "progressive-web-app",
    "icons",
    "asset-generator",
    "ios",
    "android",
    "windows11",
    "windows",
    "cli",
    "sharp",
    "image",
    "resize",
    "favicon",
    "ico",
    "manifest",
    "apple-touch-icon",
    "splash-screen",
    "web-app-manifest"
  ],
  "author": "SivaramPg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SivaramPg/pwa-icons.git"
  },
  "homepage": "https://github.com/SivaramPg/pwa-icons#readme",
  "bugs": {
    "url": "https://github.com/SivaramPg/pwa-icons/issues"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@resvg/resvg-js": "^2.6.2",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "p-limit": "^7.3.0",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "overrides": {
    "picomatch": "^4.0.5",
    "rollup": "^4.62.2"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
